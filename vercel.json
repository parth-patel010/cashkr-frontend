{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cash-kr.vercel.app" }],
      "destination": "https://www.devicekart.in/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*\\.(?:jpg|jpeg|png|svg|webp|ico|woff2))",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
